v_EmpRecord = Employees[Employee_Email == zoho.loginuserid];
for each  v_Emp in v_EmpRecord
{
	input.Employee_First_Name = v_Emp.Employee_First_Name;
	input.Employee_Last_Name = v_Emp.Employee_Last_Name;
	input.Employee_Title = v_Emp.Employee_Title;
	input.Employee_Initials = v_Emp.Employee_Initials;
	break;
}

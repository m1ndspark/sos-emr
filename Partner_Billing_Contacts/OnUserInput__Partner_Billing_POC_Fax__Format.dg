v_Raw = input.Partner_Billing_POC_Fax.toString();
v_Digits = v_Raw.replaceAll("[^0-9]","");
if(v_Digits.length() != 10)
{
	if(v_Raw != v_Digits)
	{
		input.Partner_Billing_POC_Fax = v_Digits;
	}
	return;
}
v_Formatted = v_Digits.subString(0,3) + "-" + v_Digits.subString(3,6) + "-" + v_Digits.subString(6,10);
if(v_Raw == v_Formatted)
{
	return;
}
input.Partner_Billing_POC_Fax = v_Formatted;
